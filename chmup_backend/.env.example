# Порт сервера
PORT=3000

# JWT секрет для авторизации (замени на свой случайный ключ)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# База данных SQLite файл
DATABASE_PATH=./data/chmup.db

# API ключи бирж (опционально, пользователи могут добавлять свои)
BYBIT_API_KEY=
BYBIT_API_SECRET=
BINGX_API_KEY=
BINGX_API_SECRET=
BINANCE_API_KEY=
BINANCE_API_SECRET=

# Режим работы (development или production)
NODE_ENV=development
